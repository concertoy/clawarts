{
  "name": "clawarts",
  "version": "0.1.0",
  "description": "Multi-agent Slack bot for course management with tutor/student roles",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clawarts": "dist/cli/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "check": "tsx src/cli/index.ts check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "release": "./scripts/build-release.sh"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@mozilla/readability": "^0.6.0",
    "@slack/bolt": "^4.6.0",
    "commander": "^14.0.3",
    "dotenv": "^16.4.0",
    "gray-matter": "^4.0.3",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
